        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "fastSphericalUV",
    "m_FunctionSource": "",
    "m_FunctionBody": "float3 reflectionVector = reflect(-viewDirWS, normalWS);\r\nreflectionVector = normalize(reflectionVector);\r\nuv = float2(reflectionVector.x / 4.01 + 0.5, reflectionVector.y / 4.01 + 0.5);\r"
}

